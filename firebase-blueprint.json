{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChecklistItem": {
      "title": "Checklist Item",
      "description": "A single item in the user's voter journey checklist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "label": { "type": "string" },
        "completed": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "taskId", "completed"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "users/{userId}/checklist/{taskId}": {
      "schema": "ChecklistItem",
      "description": "User specific voter checklist items"
    }
  }
}
