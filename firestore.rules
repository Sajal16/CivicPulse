rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 255;
    }

    // Checklist Item Validation
    function isValidChecklistItem(data) {
      return data.keys().hasAll(['userId', 'taskId', 'completed', 'label']) &&
             data.userId == request.auth.uid &&
             data.taskId is string &&
             data.completed is bool &&
             data.label is string && data.label.size() <= 500;
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
      );

      match /checklist/{taskId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChecklistItem(incoming());
        allow update: if isOwner(userId) && isValidChecklistItem(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'updatedAt'])
        );
        allow delete: if isOwner(userId);
      }
    }
  }
}
